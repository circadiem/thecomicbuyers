# Copy this file to .env.local and fill in your keys.
# Never commit .env.local to version control.

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# GoCollect Valuation API
GOCOLLECT_API_KEY=S9P1YBqrXHdAmjBgeUtHY9hpC6URQCpzyPLq1zZU30672f29

# Resend Transactional Email
RESEND_API_KEY=re_...

# Supabase (PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=

# File Storage (S3 or Cloudflare R2)
S3_BUCKET_NAME=thecomicbuyers-uploads
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Internal notification recipient
INTAKE_EMAIL=intake@thecomicbuyers.com

# Public site URL (used for QR codes and links in PDF reports)
NEXT_PUBLIC_SITE_URL=https://thecomicbuyers.com
